PORT=5000
GEMINI_API_KEY=AIzaSy...        # Required: Gemini API key for embeddings + LLM (when not using local models)
GITHUB_TOKEN=ghp_...          # Optional: GitHub PAT for private repos / higher rate limits

# --- Local Model (Ollama) Configuration ---
# Set USE_LOCAL_MODEL=true to run fully offline via Ollama, bypassing Gemini API quota
USE_LOCAL_MODEL=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=gemma3:latest
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest
